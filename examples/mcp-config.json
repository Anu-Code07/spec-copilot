{
  "mcpServers": {
    "specdrive": {
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/@specdrive/mcp/bin/mcp.js"],
      "cwd": "${workspaceFolder}",
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}"
      }
    }
  }
}
